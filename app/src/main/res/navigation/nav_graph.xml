<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.androidsilencerapp.ui.splash.SplashFragment"
        android:label="Splash"
        tools:layout="@layout/fragment_splash">
        <action
            android:id="@+id/action_splash_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_splash_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.androidsilencerapp.ui.auth.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_login_to_signup"
            app:destination="@id/signUpFragment" />
        <action
            android:id="@+id/action_login_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/signUpFragment"
        android:name="com.example.androidsilencerapp.ui.auth.SignUpFragment"
        android:label="Sign Up"
        tools:layout="@layout/fragment_sign_up">
        <action
            android:id="@+id/action_signup_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.example.androidsilencerapp.ui.dashboard.DashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_dashboard">
        <action
            android:id="@+id/action_dashboard_to_addProfile"
            app:destination="@id/addProfileFragment" />
        <action
            android:id="@+id/action_dashboard_to_profileDetail"
            app:destination="@id/profileDetailFragment" />
        <action
            android:id="@+id/action_dashboard_to_logs"
            app:destination="@id/logsFragment" />
        <action
            android:id="@+id/action_dashboard_to_account"
            app:destination="@id/accountFragment" />
        <action
            android:id="@+id/action_dashboard_to_settings"
            app:destination="@id/settingsFragment" />
    </fragment>

    <fragment
        android:id="@+id/addProfileFragment"
        android:name="com.example.androidsilencerapp.ui.profile.AddProfileFragment"
        android:label="Add Profile"
        tools:layout="@layout/fragment_add_profile">
        <argument
            android:name="profileId"
            android:defaultValue="@null"
            app:argType="string"
            app:nullable="true" />
        <action
            android:id="@+id/action_addProfile_to_timeSelection"
            app:destination="@id/timeSelectionFragment" />
        <action
            android:id="@+id/action_addProfile_to_locationSelection"
            app:destination="@id/locationSelectionFragment" />
        <action
            android:id="@+id/action_addProfile_to_appSelection"
            app:destination="@id/appSelectionFragment" />
        <action
            android:id="@+id/action_addProfile_to_deviceStateConfig"
            app:destination="@id/deviceStateConfigFragment" />
    </fragment>

    <fragment
        android:id="@+id/profileDetailFragment"
        android:name="com.example.androidsilencerapp.ui.profile.ProfileDetailFragment"
        android:label="Profile Detail"
        tools:layout="@layout/fragment_profile_detail">
        <argument
            android:name="profileId"
            app:argType="string" />
        <action
            android:id="@+id/action_profileDetail_to_addProfile"
            app:destination="@id/addProfileFragment" />
    </fragment>

    <fragment
        android:id="@+id/logsFragment"
        android:name="com.example.androidsilencerapp.ui.logs.LogsFragment"
        android:label="Activity Logs"
        tools:layout="@layout/fragment_logs" />

    <fragment
        android:id="@+id/accountFragment"
        android:name="com.example.androidsilencerapp.ui.account.AccountFragment"
        android:label="Account"
        tools:layout="@layout/fragment_account">
        <action
            android:id="@+id/action_account_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.example.androidsilencerapp.ui.settings.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings">
        <action
            android:id="@+id/action_settings_to_cloudSync"
            app:destination="@id/cloudSyncSettingsFragment" />
        <action
            android:id="@+id/action_settings_to_permissionManager"
            app:destination="@id/permissionManagerFragment" />
    </fragment>

    <fragment
        android:id="@+id/cloudSyncSettingsFragment"
        android:name="com.example.androidsilencerapp.ui.settings.CloudSyncSettingsFragment"
        android:label="Cloud Sync"
        tools:layout="@layout/fragment_cloud_sync_settings" />

    <fragment
        android:id="@+id/permissionManagerFragment"
        android:name="com.example.androidsilencerapp.ui.settings.PermissionManagerFragment"
        android:label="Permission Manager"
        tools:layout="@layout/fragment_permission_manager" />

    <fragment
        android:id="@+id/timeSelectionFragment"
        android:name="com.example.androidsilencerapp.ui.trigger.TimeSelectionFragment"
        android:label="Select Time"
        tools:layout="@layout/fragment_time_selection" />

    <fragment
        android:id="@+id/locationSelectionFragment"
        android:name="com.example.androidsilencerapp.ui.trigger.LocationSelectionFragment"
        android:label="Select Location"
        tools:layout="@layout/fragment_location_selection" />

    <fragment
        android:id="@+id/appSelectionFragment"
        android:name="com.example.androidsilencerapp.ui.trigger.AppSelectionFragment"
        android:label="Select Apps"
        tools:layout="@layout/fragment_app_selection" />

    <fragment
        android:id="@+id/deviceStateConfigFragment"
        android:name="com.example.androidsilencerapp.ui.trigger.DeviceStateConfigFragment"
        android:label="Device State"
        tools:layout="@layout/fragment_device_state_config" />

</navigation>